{
  "$schema": "https://www.schemastore.org/tsconfig",
  "_version": "26.0.0",

  "compilerOptions": {
    "lib": ["es2025", "ESNext.Collection", "ESNext.Temporal"],
    "module": "nodenext",
    "target": "es2025",

    "types": ["node"],
    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "noEmit": true,

    "paths": {
      "@/*": ["./src/*"],
      "@application/*": ["./src/application/*"],
      "@domain/*": ["./src/domain/*"],
      "@infra/*": ["./src/infra/*"],
      "@shared/*": ["./src/shared/*"],
      "@use-cases/*": ["./src/application/use-cases/*"],
      "@errors/*": ["./src/application/errors/*"],
      "@entities/*": ["./src/domain/entities/*"],
      "@repositories/*": ["./src/domain/repositories/*"],
      "@controllers/*": ["./src/infra/http/controllers/*"],
      "@middlewares/*": ["./src/infra/http/middlewares/*"],
      "@factories/*": ["./src/infra/http/factories/*"],
      "@database/*": ["./src/infra/database/*"]
    }
  }
}
