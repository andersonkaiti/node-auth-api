{
  "$schema": "https://www.schemastore.org/tsconfig",
  "_version": "26.0.0",

  "compilerOptions": {
    "lib": ["es2025", "ESNext.Collection", "ESNext.Temporal"],
    "module": "nodenext",
    "target": "es2025",

    "types": ["node"],
    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
